PORT=3000
DATABASE_URL=host=localhost user=postgres password=postgres dbname=kirimaja port=5432 sslmode=disable TimeZone=Asia/Jakarta
JWT_SECRET_KEY=your_secret_key
JWT_EXPIRES_IN=24h
OPENCAGE_API_KEY=your_opencage_api_key
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_ENV=sandbox
REDIS_URL=localhost:6379
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_EMAIL_SENDER=your@email.com
FRONTEND_URL=http://localhost:5173
PUBLIC_DIR=./public

# MinIO object storage (required — app refuses to start without these).
# Local runs: both endpoints localhost. docker-compose overrides
# MINIO_ENDPOINT/MINIO_PUBLIC_ENDPOINT for container networking.
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kirimaja
MINIO_USE_SSL=false
MINIO_PRESIGN_EXPIRY=15m
